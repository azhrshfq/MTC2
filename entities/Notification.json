{
  "name": "Notification",
  "type": "object",
  "properties": {
    "member_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "payment_reminder",
        "grace_period",
        "approval",
        "rejection",
        "general"
      ]
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "action_url": {
      "type": "string"
    }
  },
  "required": [
    "member_id",
    "title",
    "message"
  ]
}
